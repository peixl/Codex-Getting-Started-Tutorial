{
  "name": "codex-getting-started-tutorial",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "description": "Concise Codex desktop guide for people who know the work (Windows & macOS)",
  "scripts": {
    "dev": "next dev",
    "build:next": "next build && node scripts/prepare-standalone.mjs",
    "build": "npm run build:next && opennextjs-cloudflare build --skipNextBuild",
    "start": "node .next/standalone/server.js",
    "test": "vitest run",
    "lint": "eslint .",
    "prompt:stats": "node scripts/prompt-stats.mjs",
    "deploy": "npm run build && opennextjs-cloudflare deploy",
    "preview": "npm run build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "next": "^15.5.18",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "2.5.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/node": "^25.9.3",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "autoprefixer": "10.5.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.5.0",
    "eslint-config-next": "^16.2.9",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.100.0"
  }
}
