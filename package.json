{
  "name": "codex-getting-started-tutorial",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "description": "Beginner-friendly Codex desktop tutorial site for non-developers (Windows & macOS)",
  "scripts": {
    "dev": "next dev",
    "build:next": "next build",
    "build": "npm run build:next && opennextjs-cloudflare build --skipNextBuild",
    "start": "next start",
    "test": "vitest run",
    "lint": "eslint .",
    "prompt:stats": "node scripts/prompt-stats.mjs",
    "deploy": "npm run build && opennextjs-cloudflare deploy",
    "preview": "npm run build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types"
  },
  "overrides": {
    "postcss": "8.5.14"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "next": "^15.5.18",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "2.5.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@opennextjs/cloudflare": "^1.19.9",
    "@types/node": "^25.7.0",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "autoprefixer": "10.5.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.6",
    "postcss": "8.5.14",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.90.0"
  }
}
